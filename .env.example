# Port the addon server runs on (Default: 7860)
PORT=7860

# Public URL of your deployed addon (e.g., https://stremio-tg.yourdomain.com)
ADDON_URL=http://localhost:7860

# Optional API Key to secure your addon (e.g., Gvi4ShwFyYz...)
API_KEY=

# Telegram API credentials from https://my.telegram.org
API_ID=
API_HASH=

# Telegram Bot Token from @BotFather (required if USER_SESSION_STRING is not set)
BOT_TOKEN=

# Telegram User Session String (highly recommended to bypass 2GB file limit)
USER_SESSION_STRING=

# Comma-separated list of Telegram Channel IDs to index (e.g., -100xxxxxxxxxx, -100yyyyyyyyyy)
TELEGRAM_CHANNEL_ID=

# Optional: Channel ID to send play/stream logs to (e.g., -100zzzzzzzzzz)
LOG_CHANNEL_ID=

# Optional: Timezone for logging (e.g., Asia/Kolkata, UTC). Defaults to UTC.
TIMEZONE=UTC

# Optional: Cache duration in secon
ds for search queries (Default: 1800)
CACHE_TTL=1800

# API Key của nhà cung cấp Debrid (Yêu cầu tài khoản trả phí cho cả Real-Debrid và TorBox để dùng API)
REAL_DEBRID_API_KEY=
TORBOX_API_KEY=your_torbox_api_key

# Tự động tải từ Debrid và upload ngược lên kênh Telegram riêng tư của bạn (True/False)
AUTO_UPLOAD_TO_TELEGRAM=True

# Giới hạn số lượng kết quả torrent hiển thị trên Stremio (Mặc định: 10)
MAX_TORRENT_RESULTS=10

# Cấu hình tìm kiếm torrent nâng cao nếu bạn dùng Jackett/Prowlarr (Tùy chọn)
JACKETT_URL=
JACKETT_API_KEY=
PROWLARR_URL=
PROWLARR_API_KEY=

# qBittorrent Settings
QBITTORRENT_URL=http://localhost:8080
QBITTORRENT_USER=admin
QBITTORRENT_PASS=adminadmin

# Optional path mapping (leave empty if addon runs on the same system)
QBITTORRENT_PLAY_DIR=

# Auto Vietnamese Subtitle generation settings (Optional)
# AUTO_VIET_SUB: Set to True to enable automatic translation/generation of Vietnamese subtitles (Default: True)
AUTO_VIET_SUB=True
# GEMINI_API_KEY: Optional Gemini API Key for high-quality translation and audio transcription when no subtitles exist
GEMINI_API_KEY=

# Custom AI Translation API Settings (Optional)
# CUSTOM_AI_API_URL: Custom endpoint URL (e.g., http://localhost:20128/v1/chat/completions)
CUSTOM_AI_API_URL=
# CUSTOM_AI_API_KEY: Authorization Bearer Token for custom endpoint
CUSTOM_AI_API_KEY=
# CUSTOM_AI_MODEL: Custom AI model name (Default: cc/claude-opus-4-6)
CUSTOM_AI_MODEL=cc/claude-opus-4-6
# CUSTOM_AI_STREAM: Enable streaming translation response (True/False, Default: True)
CUSTOM_AI_STREAM=True
# SUBTITLE_TRANSLATION_SOURCE: Source to translate from ('sub' for existing subtitles, 'audio' to transcribe audio directly, Default: sub)
SUBTITLE_TRANSLATION_SOURCE=sub



