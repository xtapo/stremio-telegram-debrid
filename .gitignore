# pyenv
#   For a library or app, you might want to share your .python-version if you're
#   using pyenv and micro-managing it, but associated state files or virtualenvs
#   should not be shared.
.python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if used with a newer Pipenv version or different OS,
#   Pipfile.lock may generate conflicts.
#Pipfile.lock

# poetry
#   Similar to Pipenv, Pyproject.toml should be vcs'ed. Poetry.lock of applications should be vcs'ed.
#poetry.lock

# pdm
#   Similar to Pipenv and Poetry, pdm.lock should be vcs'ed.
#pdm.lock
#   pdm local configuration
.pdm-python.path
.pdm-build/

# PEP 582; used by e.g. github.com/lincolnloop/layman and github.com/pdm-project/pdm
__pypackages__/

